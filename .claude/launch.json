{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Python static server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "5173"],
      "port": 5173
    },
    {
      "name": "Node http-server (npx)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "http-server", ".", "-p", "8080", "-c-1"],
      "port": 8080
    },
    {
      "name": "Node serve (npx)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "serve", ".", "-l", "3000"],
      "port": 3000
    }
  ]
}
